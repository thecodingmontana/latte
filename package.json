{
  "name": "latte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix-and-check": "pnpm fix && pnpm check",
    "deps": "pnpm dlx taze@latest -Ilwr",
    "deps:major": "pnpm dlx taze@latest major -Ilwr",
    "prepare": "lefthook install",
    "commit": "git add . && git cz",
    "optimize-images": "node scripts/optimize-images.mjs",
    "prebuild": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "plaiceholder": "^3.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "lefthook": "^2.1.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ultracite": "7.3.2"
  }
}
